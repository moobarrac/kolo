# Copy to .env and fill in. NEVER commit .env (see .gitignore).
#
# ── Client (frontend/) ────────────────────────────────────────────────────────
# Safe to ship to the browser. The anon key is the ONLY key the client ever sees.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Server-only (backend/jobs) ────────────────────────────────────────────────
# [INVARIANT §2.4/§14] The service-role key is used exclusively by scheduled jobs.
# It must NEVER be shipped to the client or committed. Set it in the job runtime
# environment (Supabase / GitHub Actions secret), not in any VITE_ variable.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
